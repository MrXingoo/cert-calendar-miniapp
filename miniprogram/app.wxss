/* app.wxss - 全局样式 */
page {
  background: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  --primary: #6366F1;
  --primary-light: #EEF0FF;
  --primary-dark: #4F46E5;
  --danger: #EF4444;
  --warn: #F59E0B;
  --success: #10B981;
  --bg: #f5f6fa;
  --card: #ffffff;
  --text: #1a1a1a;
  --text-secondary: #8e8e93;
  --border: #f0f0f0;
  --radius: 24rpx;
  --radius-lg: 36rpx;
  --gradient-start: #6366F1;
  --gradient-end: #8B9CF7;
}

.container {
  padding: 30rpx;
}

.card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
  color: #fff;
  border: none;
  border-radius: var(--radius);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  color: #fff;
  font-weight: 500;
  margin-right: 8rpx;
}

.status {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.status-normal {
  background: #ECFDF5;
  color: var(--success);
}

.status-warn {
  background: #FFFBEB;
  color: var(--warn);
}

.status-expired {
  background: #FEF2F2;
  color: var(--danger);
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--text-secondary);
}

.empty-state .icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state .text {
  font-size: 28rpx;
}
