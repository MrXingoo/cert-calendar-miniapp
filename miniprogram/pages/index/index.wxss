/* pages/index/index.wxss */

/* ===== 搜索栏嵌入 header ===== */
.header-search {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 80rpx;
  margin-top: 20rpx;
}

.hs-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.hs-input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  color: #fff;
}

.hs-input::placeholder {
  color: rgba(255,255,255,0.5);
}

.hs-clear {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  padding: 8rpx 0 8rpx 16rpx;
  flex-shrink: 0;
}

/* ===== 下拉 ===== */
.dd-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 90;
}

.dropdown {
  position: absolute;
  left: 32rpx; right: 32rpx;
  top: 280rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  z-index: 100;
  padding: 8rpx 0;
  animation: ddIn 0.2s ease;
}

@keyframes ddIn {
  from { opacity: 0; transform: translateY(-12rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.dd-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.dd-item:active { background: #f7f8fa; }

.dd-item.active {
  color: #6366F1;
  font-weight: 600;
  background: #EEF0FF;
}

.dd-check {
  color: #6366F1;
  font-weight: 700;
  font-size: 30rpx;
}

/* ===== 筛选条 ===== */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 16rpx 32rpx 0;
  padding: 14rpx 24rpx;
  background: #EEF0FF;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 500;
}

.bar-close {
  font-size: 22rpx;
  opacity: 0.7;
}

/* ===== 证照卡片列表 ===== */
.cert-list {
  padding: 16rpx 32rpx 200rpx;
}

.cert-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.03);
  transition: transform 0.15s;
}

.cert-card:active {
  transform: scale(0.98);
}

/* 图标 */
.cc-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

/* 正文 */
.cc-body {
  flex: 1;
  min-width: 0;
}

.cc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.cc-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.cc-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.cc-badge.normal {
  background: #ECFDF5;
  color: #10B981;
}

.cc-badge.warn {
  background: #FFFBEB;
  color: #F59E0B;
}

.cc-badge.expired {
  background: #FEF2F2;
  color: #EF4444;
}

/* 时间线 */
.cc-timeline {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
}

.cc-date-label {
  font-size: 22rpx;
  color: #8e8e93;
}

.cc-date-label.permanent {
  color: #10B981;
  font-weight: 500;
}

.cc-arrow {
  font-size: 20rpx;
  color: #c7c7cc;
}

.cc-countdown {
  font-size: 22rpx;
  font-weight: 500;
}

.cc-countdown.normal {
  color: #10B981;
}

.cc-countdown.warn {
  color: #F59E0B;
}

.cc-countdown.expired {
  color: #EF4444;
}

.cc-date-simple {
  font-size: 22rpx;
  color: #8e8e93;
}

/* 箭头 */
.cc-arrow-end {
  font-size: 32rpx;
  color: #ccc;
}

/* 空状态 & loading */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #8e8e93;
  font-size: 24rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #6366F1, #8B9CF7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 28rpx rgba(99,102,241,0.35);
  z-index: 50;
  transition: transform 0.2s;
}

.fab:active {
  transform: scale(0.9);
}
