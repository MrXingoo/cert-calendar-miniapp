<!-- pages/history/history.wxml -->
<view class="history-header">
  <view class="back" bindtap="goBack">← 返回</view>
  <view class="h-title">{{certName}} - 变更记录</view>
  <view class="sub">共 {{historyList.length}} 条变更 · 当前版本 v{{currentVersion}}</view>
</view>

<view class="timeline">
  <view class="timeline-item" wx:for="{{historyList}}" wx:key="version">
    <view class="dot {{index === 0 ? 'current' : ''}}"></view>
    <view class="card">
      <view class="card-top">
        <text class="card-time">{{item._time}}</text>
        <text class="card-ver">v{{item.version}}</text>
      </view>
      <view class="card-title">{{index === 0 ? '最新变更' : '历史变更'}}</view>
      <view class="card-snapshot" wx:for="{{item.changes}}" wx:for-item="ch" wx:key="field">
        <text class="label">{{ch.field}}：</text>
        <text class="old-val" wx:if="{{ch.old !== '(空)' && ch.old !== '初始创建'}}">{{ch.old}}</text>
        <text class="arrow" wx:if="{{ch.old !== '(空)' && ch.old !== '初始创建'}}"> → </text>
        <text class="new-val">{{ch.new}}</text>
      </view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="text">加载中...</view>
  </view>

  <view class="empty-state" wx:if="{{!loading && historyList.length === 0}}">
    <view class="icon">◇</view>
    <view class="text">暂无变更记录</view>
  </view>
</view>
