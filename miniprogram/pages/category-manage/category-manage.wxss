/* pages/category-manage/category-manage.wxss */

.cm-page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* ===== 顶部 ===== */
.cm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 24rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B9CF7 100%);
  position: relative;
}

.cm-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  background: rgba(255,255,255,0.18);
  border-radius: 50%;
}
.cm-back:active { background: rgba(255,255,255,0.3); }

.cm-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.cm-add {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  background: rgba(255,255,255,0.18);
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}
.cm-add:active { background: rgba(255,255,255,0.3); }

/* ===== 列表 ===== */
.cm-list {
  padding: 24rpx;
}

.cm-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  gap: 20rpx;
}

.cm-color {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.cm-info {
  flex: 1;
  min-width: 0;
}

.cm-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.cm-color-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cm-color-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.cm-color-text {
  font-size: 22rpx;
  color: #6b7280;
  font-family: monospace;
}

.cm-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.cm-btn {
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.cm-btn.edit {
  background: #E8EAFF;
  color: #5B6EF5;
}
.cm-btn.del {
  background: #FFECEF;
  color: #F25C5C;
}
.cm-btn:active { opacity: 0.7; }

.cm-empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #6b7280;
  font-size: 28rpx;
}

/* ===== 底部重置 ===== */
.cm-footer {
  padding: 24rpx;
  text-align: center;
}

.cm-reset {
  display: inline-block;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  color: #6b7280;
  background: #fff;
  border-radius: 32rpx;
  border: 2rpx solid #e5e7eb;
}
.cm-reset:active { background: #f7f8fa; }

/* ===== 弹层 ===== */
.cm-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.cm-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: sheetIn 0.25s ease;
}

@keyframes sheetIn {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.cm-sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.cm-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.cm-sheet-close {
  font-size: 36rpx;
  color: #6b7280;
  padding: 8rpx 16rpx;
}

.cm-sheet-body {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.cm-sheet-footer {
  display: flex;
  padding: 16rpx 24rpx 32rpx;
  gap: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.sheet-btn.cancel {
  background: #f7f8fa;
  color: #6b7280;
}
.sheet-btn.confirm {
  background: linear-gradient(135deg, #5B6EF5, #8B9CF7);
  color: #fff;
}
.sheet-btn:active { opacity: 0.8; }

/* ===== 表单 ===== */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.form-input {
  height: 88rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1f2937;
  display: flex;
  align-items: center;
}

/* 颜色预览 */
.color-preview {
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-family: monospace;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.2);
}

/* 选择器 */
.picker-panel {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f7f8fa;
  border-radius: 20rpx;
}

.picker-title {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.picker-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.picker-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}
.picker-item:active {
  border-color: #5B6EF5;
  background: #E8EAFF;
}

.color-grid {
  gap: 16rpx;
}

.picker-color {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}
.picker-color:active {
  border-color: #1f2937;
  transform: scale(1.1);
}

.color-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e0e0e0;
}

.color-input-label {
  font-size: 24rpx;
  color: #6b7280;
  white-space: nowrap;
}

.color-input {
  flex: 1;
  height: 64rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  font-family: monospace;
}
