<!-- pages/calendar/calendar.wxml -->
<view class="cal-page">

  <!-- 顶部 -->
  <view class="gradient-header">
    <view class="status-bar-spacer" style="height:{{statusBarHeight}}px"></view>
    <view class="header-row">
      <view class="header-avatar">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill" />
        <text wx:else class="ph">◉</text>
        <button class="header-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar"></button>
      </view>
      <view class="header-info">
        <view class="header-title">工作日历</view>
        <view class="header-date">{{currentYear}}年{{currentMonth}}月</view>
        <view class="header-sub">{{lunarMonthText}} · {{ganZhiYear}}年</view>
      </view>
      <view class="cal-nav-arrow" bindtap="prevMonth">‹</view>
      <view class="cal-nav-arrow" bindtap="nextMonth">›</view>
      <view class="header-action" bindtap="goToday">今</view>
    </view>

    <!-- 分类统计（点击切换分类） -->
    <view class="stats-bar">
      <view class="stats-item" bindtap="onStatCatTap" data-slot="1">
        <view class="stats-num" style="color:{{statCat1Info.color}}">{{statDays1}}</view>
        <view class="stats-label">{{statCat1Info.name}}</view>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="onStatCatTap" data-slot="2">
        <view class="stats-num" style="color:{{statCat2Info.color}}">{{statDays2}}</view>
        <view class="stats-label">{{statCat2Info.name}}</view>
      </view>
    </view>
  </view>

  <!-- 星期头 -->
  <view class="weekday-header">
    <text class="wd-item" wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this"
          style="{{index===5||index===6?'color:#EF4444':''}}">{{item}}</text>
  </view>

  <!-- 日历网格（左右滑动切月） -->
  <view class="cal-body" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
    <view class="cal-row" wx:for="{{weeks}}" wx:key="index" wx:for-item="week">
      <view class="cal-cell {{item.isCurrentMonth?'current':'other'}} {{item.isToday?'today':''}}"
            wx:for="{{week}}" wx:key="fullDate" wx:for-item="item"
            bindtap="onDayTap" data-date="{{item.fullDate}}">

        <view class="cell-top">
          <view class="cell-dot" wx:if="{{item.events.length > 0}}"
                style="background:{{item.events[0].color}}"></view>
          <text class="cell-num {{item.holiday?'holiday':''}}">{{item.day}}</text>
        </view>

        <text class="cell-lunar {{item.holiday?'holiday-text':''}}">{{item.holiday || item.lunarText}}</text>

        <view class="cell-events">
          <view class="event-bar evt-{{evt.position}}"
                wx:for="{{item.events}}" wx:for-item="evt" wx:key="_id"
                style="background:{{evt.color}}"
                catchtap="onEventTap" data-id="{{evt._id}}">
            <text class="bar-text" wx:if="{{evt.isStart || evt.isSingle}}">{{evt.title}}</text>
          </view>
        </view>

      </view>
    </view>
  </view>

  <!-- 悬浮按钮 -->
  <view class="fab" bindtap="onFabTap">
    <text>+</text>
  </view>

  <!-- 日期事件弹窗 -->
  <view class="day-events-mask" wx:if="{{showDayEvents}}" bindtap="closeDayEvents"></view>
  <view class="day-events-sheet" wx:if="{{showDayEvents}}">
    <view class="sheet-header">
      <text class="sheet-date">{{dayEventsDateText}}</text>
      <text class="sheet-close" bindtap="closeDayEvents">✕</text>
    </view>
    <scroll-view scroll-y class="sheet-list">
      <view class="sheet-item" wx:for="{{dayEvents}}" wx:key="_id"
            bindtap="onEventTap" data-id="{{item._id}}">
        <view class="sheet-dot" style="background:{{item.color || '#6366F1'}}"></view>
        <view class="sheet-info">
          <text class="sheet-title">{{item.title}}</text>
          <text class="sheet-range">{{item.startDate}} ~ {{item.endDate}}</text>
        </view>
        <text class="sheet-arrow">›</text>
      </view>
      <view class="sheet-empty" wx:if="{{dayEvents.length===0}}">暂无事件</view>
    </scroll-view>
    <view class="sheet-add" bindtap="onAddEventForDate">
      ＋ 添加事件
    </view>
  </view>

</view>
