<!-- pages/index/index.wxml -->
<view class="gradient-header">
  <view class="status-bar-spacer" style="height:{{statusBarHeight}}px"></view>
  <view class="header-row">
    <view class="header-avatar">
      <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill" />
      <text wx:else class="ph">◉</text>
      <button class="header-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar"></button>
    </view>
    <view class="header-info">
      <view class="header-title">证照清单</view>
      <view class="header-sub">{{certList.length}} 张证照</view>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-bar">
    <view class="stats-item" bindtap="onFilterTap" data-status="all">
      <view class="stats-num">{{stats.total}}</view>
      <view class="stats-label">全部</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item" bindtap="onWarnCardTap">
      <view class="stats-num" style="color:#FFD93D">{{stats.warn}}</view>
      <view class="stats-label">即将到期 ▾</view>
    </view>
  </view>
</view>

<!-- 下拉菜单 -->
<view class="dd-mask" wx:if="{{showDropdown}}" bindtap="closeDropdown"></view>
<view class="dropdown" wx:if="{{showDropdown}}">
  <view class="dd-item {{warnDays === item.value ? 'active' : ''}}"
        wx:for="{{warnOptions}}" wx:key="value"
        bindtap="selectDays" data-days="{{item.value}}">
    <text>{{item.label}}</text>
    <text class="dd-check" wx:if="{{warnDays === item.value}}">✓</text>
  </view>
</view>

<!-- 筛选条 -->
<view class="filter-bar" wx:if="{{filterStatus !== 'all'}}" bindtap="clearFilter">
  <text>{{filterText}}</text>
  <text class="bar-close">✕ 清除</text>
</view>

<!-- 列表 -->
<view class="cert-list">
  <view class="cert-card" wx:for="{{certList}}" wx:key="_id"
        bindtap="goDetail" data-id="{{item._id}}">
    <image wx:if="{{item.images && item.images.length > 0}}"
           src="{{item.images[0]}}" class="cc-thumb" mode="aspectFill" />
    <view wx:else class="cc-thumb placeholder">
      <text>{{item.emoji || '●'}}</text>
    </view>
    <view class="cc-body">
      <view class="cc-top">
        <text class="cc-name">{{item.name}}</text>
        <view class="cc-badge {{item._status.type}}">{{item._status.text}}</view>
      </view>
      <view class="cc-timeline" wx:if="{{item.obtainDate || item.expireDate}}">
        <text wx:if="{{item.obtainDate}}" class="cc-date-label">取证 {{item.obtainDate}}</text>
        <text wx:if="{{item.obtainDate && (item.expireDate || item.isPermanent)}}" class="cc-arrow">→</text>
        <text wx:if="{{item.isPermanent}}" class="cc-date-label permanent">永久有效</text>
        <text wx:elif="{{item.expireDate}}" class="cc-date-label">到期 {{item.expireDate}}</text>
        <text wx:if="{{item._status.countdown}}" class="cc-countdown {{item._status.type}}">· {{item._status.countdown}}</text>
      </view>
      <view class="cc-date-simple" wx:elif="{{item.expireDate || item.isPermanent}}">
        <text>{{item.isPermanent ? '永久有效' : '到期 ' + item.expireDate}}</text>
      </view>
    </view>
    <view class="cc-arrow-end">›</view>
  </view>

  <view class="empty-state" wx:if="{{!loading && certList.length === 0}}">
    <view class="icon">◇</view>
    <view class="text">暂无证照</view>
    <view style="font-size:24rpx;color:#6b7280;margin-top:8rpx">点击右下角 + 添加</view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
</view>

<!-- 悬浮按钮 -->
<view class="fab" bindtap="goAdd">
  <text>+</text>
</view>
