/* pages/index/index.wxss */

/* ===== 下拉 ===== */
.dd-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 90;
}

.dropdown {
  position: absolute;
  left: 32rpx; right: 32rpx;
  top: 260rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  z-index: 100;
  padding: 8rpx 0;
  animation: ddIn 0.2s ease;
}

@keyframes ddIn {
  from { opacity: 0; transform: translateY(-12rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.dd-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #1f2937;
}

.dd-item:active { background: #f7f8fa; }

.dd-item.active {
  color: #6366F1;
  font-weight: 600;
  background: #EEF0FF;
}

.dd-check {
  color: #6366F1;
  font-weight: 700;
  font-size: 30rpx;
}

/* ===== 筛选条 ===== */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 16rpx 32rpx 0;
  padding: 14rpx 24rpx;
  background: #EEF0FF;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 500;
}

.bar-close {
  font-size: 22rpx;
  opacity: 0.7;
}

/* ===== 证照卡片列表 ===== */
.cert-list {
  padding: 16rpx 32rpx 200rpx;
}

.cert-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  border: 1rpx solid #eef0f2;
  transition: transform 0.15s;
}

.cert-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

/* 缩略图 */
.cc-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f3f4f6;
}

.cc-thumb.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #9ca3af;
}

/* 正文 */
.cc-body {
  flex: 1;
  min-width: 0;
}

.cc-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.cc-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.cc-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.cc-badge.normal {
  background: #D1FAE5;
  color: #059669;
}

.cc-badge.warn {
  background: #FEF3C7;
  color: #D97706;
}

.cc-badge.expired {
  background: #FEE2E2;
  color: #DC2626;
}

/* 时间线 */
.cc-timeline {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
}

.cc-date-label {
  font-size: 22rpx;
  color: #6b7280;
}

.cc-date-label.permanent {
  color: #059669;
  font-weight: 600;
}

.cc-arrow {
  font-size: 20rpx;
  color: #9ca3af;
}

.cc-countdown {
  font-size: 22rpx;
  font-weight: 600;
}

.cc-countdown.normal {
  color: #059669;
}

.cc-countdown.warn {
  color: #D97706;
}

.cc-countdown.expired {
  color: #DC2626;
}

.cc-date-simple {
  font-size: 22rpx;
  color: #6b7280;
}

/* 箭头 */
.cc-arrow-end {
  font-size: 32rpx;
  color: #9ca3af;
}

/* 空状态 & loading */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #6b7280;
  font-size: 24rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #6366F1, #8B9CF7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 28rpx rgba(99,102,241,0.35);
  z-index: 50;
  transition: transform 0.2s;
}

.fab:active {
  transform: scale(0.9);
}
