/* pages/calendar/calendar.wxss */

.cal-page {
  min-height: 100vh;
  background: #f5f6fa;
  display: flex;
  flex-direction: column;
}

/* ===== 月份切换工具条 ===== */
.month-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 12rpx 20rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.mt-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #6366F1;
  font-weight: 500;
  border-radius: 50%;
}

.mt-arrow:active { background: #EEF0FF; }

.mt-label {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

/* ===== 星期头 ===== */
.weekday-header {
  display: flex;
  padding: 14rpx 8rpx 6rpx;
}

.wd-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

/* ===== 日历网格 ===== */
.cal-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 6rpx 40rpx;
}

.cal-row {
  display: flex;
  flex: 1;
  min-height: 0;
}

.cal-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 3rpx 4rpx;
  border-radius: 12rpx;
  position: relative;
  min-width: 0;
  overflow: hidden;
}

.cal-cell.current {
  background: #fff;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.06);
}

.cal-cell.other { opacity: 0.3; }

/* 今日 - 圆和普通数字高度一致，不撑开格子 */
.cal-cell.today .cell-num {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  background: #6366F1;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  font-weight: 700;
  font-size: 26rpx;
  display: inline-block;
}

/* 日期数字容器 - 固定高度保证所有格子顶部对齐 */
.cell-top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  height: 46rpx;
  width: 100%;
  flex-shrink: 0;
}

.cell-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.cell-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
}

.cell-num.holiday { color: #DC2626; }

/* 农历文字 - 固定高度，无内容也占位 */
.cell-lunar {
  font-size: 18rpx;
  color: #787878;
  height: 26rpx;
  line-height: 26rpx;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  width: 100%;
  flex-shrink: 0;
}

.cell-lunar.holiday-text {
  color: #DC2626;
  font-weight: 600;
}

/* ===== 事件色条 ===== */
.cell-events {
  width: 100%;
  margin-top: 2rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  overflow: hidden;
  justify-content: flex-start;
}

.event-bar {
  width: 100%;
  min-height: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 6rpx;
  overflow: hidden;
  border-radius: 6rpx;
  opacity: 0.95;
  flex-shrink: 0;
}

/* 跨天连续：去掉圆角实现视觉连接 */
.event-bar.evt-start  { border-radius: 6rpx 0 0 6rpx; }
.event-bar.evt-middle { border-radius: 0; }
.event-bar.evt-end    { border-radius: 0 6rpx 6rpx 0; }

.bar-text {
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #fff;
  font-weight: 500;
  padding-left: 4rpx;
}

/* ===== 悬浮按钮 ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #6366F1, #8B9CF7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 28rpx rgba(99,102,241,0.35);
  z-index: 50;
  transition: transform 0.2s;
}

.fab:active { transform: scale(0.9); }

/* ===== 日期事件弹窗 ===== */
.day-events-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.day-events-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 101;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  animation: sheetIn 0.25s ease;
}

@keyframes sheetIn {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 14rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.sheet-date {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.sheet-close {
  font-size: 36rpx;
  color: #6b7280;
  padding: 8rpx 16rpx;
}

.sheet-list {
  flex: 1;
  padding: 8rpx 28rpx;
  max-height: 40vh;
}

.sheet-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  gap: 18rpx;
}

.sheet-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sheet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.sheet-range {
  font-size: 22rpx;
  color: #6b7280;
}

.sheet-arrow {
  font-size: 32rpx;
  color: #9ca3af;
}

.sheet-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #6b7280;
  font-size: 28rpx;
}

.sheet-add {
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #6366F1;
  border-top: 1rpx solid #e5e7eb;
}

.sheet-add:active { background: #f7f8fa; }
