/* pages/calendar/calendar.wxss */

.cal-page {
  min-height: 100vh;
  background: #f5f6fa;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部 ===== */
.cal-header {
  background: linear-gradient(135deg, #6366F1 0%, #8B9CF7 100%);
  padding: 0 32rpx 36rpx;
}

.status-bar-spacer {
  width: 100%;
}

.header-top {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.header-info {
  flex: 1;
  min-width: 0;
}

/* 头像 */
.avatar-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.avatar-trigger {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  padding: 0;
  margin: 0;
  border: none;
  min-height: 0;
}

.avatar-trigger::after {
  border: none;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

.header-right {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  font-weight: 600;
  flex-shrink: 0;
}
.header-right:active {
  background: rgba(255, 255, 255, 0.3);
}

/* ===== 分类统计条（仿清单页） ===== */
.cal-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 24rpx 0;
  margin-top: 28rpx;
  backdrop-filter: blur(20px);
}

.cal-stat {
  flex: 1;
  text-align: center;
}

.cal-stat-num {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.cal-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.cal-stat-icon {
  font-size: 24rpx;
}

.cal-stat:active {
  opacity: 0.7;
}

.cal-stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ===== 月份切换工具条 ===== */
.month-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.mt-arrow {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #6366F1;
  font-weight: 600;
  border-radius: 50%;
}
.mt-arrow:active {
  background: #EEF0FF;
}

.mt-label {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* ===== 星期头 ===== */
.weekday-header {
  display: flex;
  padding: 16rpx 8rpx 8rpx;
  background: #f5f6fa;
}

.wd-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #8e8e93;
  font-weight: 500;
}

/* ===== 日历网格 ===== */
.cal-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 8rpx 40rpx;
}

.cal-row {
  display: flex;
  flex: 1;
  min-height: 0;
}

.cal-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 4rpx 6rpx;
  border-radius: 16rpx;
  position: relative;
  min-width: 0;
  overflow: visible;
  border: 1rpx solid transparent;
}

.cal-cell.current {
  background: #fff;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.03);
}
.cal-cell.other {
  opacity: 0.35;
}

/* 今日高亮 */
.cal-cell.today .cell-num {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: #6366F1;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  font-weight: 700;
}

.cell-top {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding-left: 4rpx;
  align-self: flex-start;
}

.cell-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.cell-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.2;
}

.cell-num.holiday {
  color: #EF4444;
}

.cell-lunar {
  font-size: 18rpx;
  color: #b0b0b0;
  margin-top: 2rpx;
  line-height: 1.2;
  text-align: center;
}

.cell-lunar.holiday-text {
  color: #EF4444;
  font-weight: 500;
}

/* ===== 事件色条 ===== */
.cell-events {
  width: calc(100% + 8rpx);
  margin-left: -4rpx;
  margin-top: 4rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
  overflow: visible;
}

.event-bar {
  width: 100%;
  min-height: 32rpx;
  display: flex;
  align-items: center;
  padding: 0 6rpx;
  overflow: hidden;
  border-radius: 0;
  opacity: 0.92;
}

/* 单日事件 */
.event-bar.evt-single {
  border-radius: 6rpx;
}

/* 跨天开始日 */
.event-bar.evt-start {
  border-radius: 6rpx 0 0 6rpx;
  width: calc(100% + 4rpx);
}

/* 跨天中间日 */
.event-bar.evt-middle {
  border-radius: 0;
  width: calc(100% + 8rpx);
  margin: 0 -4rpx;
  padding: 0 0;
}

/* 跨天结束日 */
.event-bar.evt-end {
  border-radius: 0 6rpx 6rpx 0;
  width: calc(100% + 4rpx);
  margin-left: -4rpx;
}

.bar-text {
  font-size: 18rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #fff;
  font-weight: 500;
  padding-left: 4rpx;
}

/* ===== 悬浮按钮 ===== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #6366F1, #8B9CF7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 50rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.4);
  z-index: 50;
  transition: transform 0.2s;
}
.fab:active {
  transform: scale(0.9);
}

/* ===== 日期事件弹窗 ===== */
.day-events-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}

.day-events-sheet {
  position: fixed;
  left: 0; right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
  animation: sheetIn 0.25s ease;
}

@keyframes sheetIn {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sheet-date {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.sheet-close {
  font-size: 36rpx;
  color: #8e8e93;
  padding: 8rpx 16rpx;
}

.sheet-list {
  flex: 1;
  padding: 8rpx 32rpx;
  max-height: 40vh;
}

.sheet-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f7f7f7;
  gap: 20rpx;
}

.sheet-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sheet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.sheet-range {
  font-size: 22rpx;
  color: #8e8e93;
}

.sheet-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.sheet-empty {
  text-align: center;
  padding: 60rpx 0;
  color: #8e8e93;
  font-size: 28rpx;
}

.sheet-add {
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #6366F1;
  border-top: 1rpx solid #f0f0f0;
}
.sheet-add:active {
  background: #f7f8fa;
}
