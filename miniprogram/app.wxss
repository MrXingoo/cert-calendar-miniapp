/* app.wxss - 全局样式 */
page {
  background: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
  --primary: #6366F1;
  --primary-light: #EEF0FF;
  --primary-dark: #4F46E5;
  --danger: #DC2626;
  --warn: #D97706;
  --success: #059669;
  --bg: #f5f6fa;
  --card: #ffffff;
  --text: #1f2937;
  --text-secondary: #6b7280;
  --border: #e5e7eb;
  --radius: 24rpx;
  --radius-lg: 36rpx;
  --gradient-start: #6366F1;
  --gradient-end: #8B9CF7;
}

/* ===== 共享顶部 header ===== */
.status-bar-spacer {
  width: 100%;
}

.gradient-header {
  background: linear-gradient(135deg, #6366F1 0%, #8B9CF7 100%);
  padding: 0 32rpx 24rpx;
}

.header-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.header-avatar image {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: block;
}

.header-avatar .ph {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.header-avatar-btn {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0;
  padding: 0; margin: 0;
  border: none; min-height: 0;
}

.header-avatar-btn::after { border: none; }

.header-info {
  flex: 1;
  min-width: 0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
  font-weight: 500;
}

.header-action {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6366F1;
  background: rgba(255,255,255,0.92);
  border-radius: 50%;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 178rpx;
}

.header-action:active { background: rgba(255,255,255,0.7); }

/* ===== 统计条 ===== */
.stats-bar {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.18);
  border-radius: 20rpx;
  padding: 20rpx 0;
  margin-top: 24rpx;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 6rpx;
}

.stats-divider {
  width: 2rpx;
  height: 44rpx;
  background: rgba(255,255,255,0.22);
}

/* ===== 通用卡片 ===== */
.container {
  padding: 30rpx;
}

.card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
  color: #fff;
  border: none;
  border-radius: var(--radius);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  color: #fff;
  font-weight: 500;
  margin-right: 8rpx;
}

.status {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.status-normal {
  background: #D1FAE5;
  color: var(--success);
}

.status-warn {
  background: #FEF3C7;
  color: var(--warn);
}

.status-expired {
  background: #FEE2E2;
  color: var(--danger);
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: var(--text-secondary);
}

.empty-state .icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state .text {
  font-size: 28rpx;
}
