/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #5B6EF5 0%, #8B9CF7 40%, #f7f8fa 40%);
  position: relative;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  top: -200rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx 80rpx;
  position: relative;
  z-index: 1;
}

.login-logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 8rpx 24rpx rgba(0, 0, 0, 0.15));
}

.login-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 80rpx;
}

.features {
  display: flex;
  gap: 80rpx;
  margin-bottom: 100rpx;
  background: #fff;
  padding: 48rpx 56rpx;
  border-radius: 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.feat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.feat-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.login-btn {
  width: 560rpx;
  height: 100rpx;
  background: #07C160;
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
  letter-spacing: 2rpx;
}

.login-btn:active {
  transform: scale(0.97);
}

.agree {
  margin-top: 32rpx;
  font-size: 22rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.check {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
}

.check.checked {
  background: #07C160;
  border-color: #07C160;
  color: #fff;
}

.link {
  color: var(--primary);
}

.avatar-pick-btn {
  width: 560rpx;
  height: 80rpx;
  background: transparent;
  color: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  line-height: normal;
}

.avatar-pick-btn::after {
  border: none;
}
