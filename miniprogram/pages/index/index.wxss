/* pages/index/index.wxss */
.header {
  background: linear-gradient(135deg, #6366F1 0%, #8B9CF7 100%);
  padding: 0 32rpx 36rpx;
}

.status-bar-spacer {
  width: 100%;
}

.header-top {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

.avatar-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.avatar-trigger {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  padding: 0;
  margin: 0;
  border: none;
  min-height: 0;
}

.avatar-trigger::after {
  border: none;
}

/* 统计 */
.stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  padding: 24rpx 0;
  backdrop-filter: blur(20px);
}

.stat {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  transition: text-shadow 0.2s;
}

.stat-num.active {
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.5);
}

.stat-num.warn {
  color: #FFD93D;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.stat-label .arrow {
  font-size: 18rpx;
  opacity: 0.6;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* 下拉 */
.dd-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
}

.dropdown {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 260rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  z-index: 100;
  padding: 8rpx 0;
  animation: ddIn 0.2s ease;
}

@keyframes ddIn {
  from { opacity: 0; transform: translateY(-12rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.dd-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.dd-item:active {
  background: #f7f8fa;
}

.dd-item.active {
  color: #6366F1;
  font-weight: 600;
  background: #EEF0FF;
}

.dd-check {
  color: #6366F1;
  font-weight: 700;
  font-size: 30rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 32rpx 0;
}

.search-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 80rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #c7c7cc;
  padding: 8rpx 0 8rpx 16rpx;
  flex-shrink: 0;
}

/* 筛选条 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 32rpx 0;
  padding: 14rpx 24rpx;
  background: #EEF0FF;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #6366F1;
  font-weight: 500;
}

.bar-close {
  font-size: 22rpx;
  opacity: 0.7;
}

/* 列表 */
.list {
  padding: 20rpx 32rpx 200rpx;
}

.cert-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
  border: 1rpx solid transparent;
}

.cert-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.card-badge.normal {
  background: #ECFDF5;
  color: #10B981;
}

.card-badge.warn {
  background: #FFFBEB;
  color: #F59E0B;
}

.card-badge.expired {
  background: #FEF2F2;
  color: #EF4444;
}

.card-date {
  font-size: 24rpx;
  color: #8e8e93;
}

.card-ver {
  font-size: 20rpx;
  color: #6366F1;
  background: #EEF0FF;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 600;
  display: inline-block;
  margin-top: 6rpx;
}

.card-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8e8e93;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #8e8e93;
  font-size: 24rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #6366F1, #8B9CF7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.4);
  z-index: 50;
  transition: transform 0.2s;
}

.fab:active {
  transform: scale(0.9);
}
